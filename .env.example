# Copia este archivo como .env y rellena los valores.
# NUNCA subas el .env real a GitHub.

# Turso — obtén estos datos en https://app.turso.tech
# 1. Crea una cuenta (gratis)
# 2. New Database → elige nombre (ej: saturno-shift) → region: South America
# 3. Settings → Generate Token → copia token y URL HTTPS

TURSO_URL=https://tu-base.turso.io
TURSO_AUTH_TOKEN=eyJ...token_completo...
